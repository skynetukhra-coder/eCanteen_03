# Server Port
PORT=5000

# Database Configuration (Set up in Hostinger hPanel or target server MySQL)
DB_HOST=localhost
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# JWT Configuration (Choose a long, random key for production security)
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth Client ID (If using Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id_here

# SMTP Configuration for OTP Emails
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=true
SMTP_FROM="eCanteen Admin" <your_smtp_from_email>

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
